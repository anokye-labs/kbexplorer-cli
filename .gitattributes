# Derived knowledge artifacts are byte-canonical (sorted keys, LF newlines, no
# timestamps) so `kbexplorer derive --check` is deterministic. Pin them to LF so
# autocrlf can't rewrite line endings on checkout and trip a false drift.
*.jsonld text eol=lf

# Golden snapshots are compared byte-for-byte against `canonicalStringify` output
# (always LF). Pin them to LF too, otherwise autocrlf rewrites them to CRLF on
# Windows checkouts and the content goldens fail on a pure line-ending diff.
*.golden.json text eol=lf


# Plugin command assets are deterministically rendered with LF newlines from
# src/lib/command-surface.js (see scripts/emit-commands.js --check). Pin them to
# LF so autocrlf can't rewrite line endings on Windows checkouts and trip the
# command-surface drift gate.
src/assets/commands/*.md text eol=lf
