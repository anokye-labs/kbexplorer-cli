# Derived knowledge artifacts are byte-canonical (sorted keys, LF newlines, no
# timestamps) so `kbexplorer derive --check` is deterministic. Pin them to LF so
# autocrlf can't rewrite line endings on checkout and trip a false drift.
*.jsonld text eol=lf

# Golden snapshots are compared byte-for-byte against `canonicalStringify` output
# (always LF). Pin them to LF too, otherwise autocrlf rewrites them to CRLF on
# Windows checkouts and the content goldens fail on a pure line-ending diff.
*.golden.json text eol=lf


# Plugin command assets are deterministically rendered with LF newlines from
# src/lib/command-surface.js (see scripts/emit-commands.js --check). Pin them to
# LF so autocrlf can't rewrite line endings on Windows checkouts and trip the
# command-surface drift gate.
src/assets/commands/*.md text eol=lf

# Authored content pages are embedded byte-for-byte into the content-manifest
# golden (tests/golden/content-golden.test.js, T0c.1). A Windows checkout with
# autocrlf can bake \r\n into those embedded strings even though the file
# itself is stored as LF, causing a false golden mismatch. Pin them to LF.
content/*.md text eol=lf

# Derive-baseline sample sources are hashed byte-for-byte by `kbx derive` to
# produce the sha256 embedded in their committed *.jsonld artifact (see above).
# Pin them to LF too, otherwise autocrlf rewrites them to CRLF on Windows
# checkouts and any re-derivation on Windows bakes a Windows-only hash into the
# artifact, which then fails `derive --check`'s determinism baseline on Linux CI
# (observed: content/derived/platform-squad.jsonld drifting across several PRs).
docs/samples/*.md text eol=lf
