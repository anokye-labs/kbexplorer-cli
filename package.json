{
  "name": "@anokye-labs/kbexplorer",
  "version": "0.1.0",
  "description": "CLI tool for the kbexplorer interactive knowledge base — turn any repo into a navigable knowledge graph",
  "type": "module",
  "bin": {
    "kbexplorer": "bin/cli.js"
  },
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "mcp": "node bin/cli.js mcp",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "mcp:bridge": "node scripts/mcp-sampling-bridge.mjs",
    "kb:dev": "kbexplorer dev",
    "kb:build": "kbexplorer build",
    "kb:generate": "kbexplorer generate"
  },
  "keywords": [
    "knowledge-base",
    "graph",
    "documentation",
    "code-analysis",
    "copilot"
  ],
  "author": "Anokye Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anokye-labs/kbexplorer-cli.git"
  },
  "homepage": "https://github.com/anokye-labs/kbexplorer-cli",
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
